# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Composio — https://app.composio.dev
COMPOSIO_API_KEY=

# GitHub repo to review PRs from (owner/repo format)
GITHUB_REPO=owner/repo-name
# Same value — exposes the repo name to the browser for the UI header
NEXT_PUBLIC_GITHUB_REPO=owner/repo-name

# Slack channel to post review summaries to
SLACK_CHANNEL=#pr-reviews

# SQLite database path (this default works out of the box)
DATABASE_URL=file:./prisma/dev.db

# Optional: GitHub webhook secret for /api/webhook signature verification
GITHUB_WEBHOOK_SECRET=
